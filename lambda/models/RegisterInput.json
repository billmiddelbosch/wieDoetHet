{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "title": "RegisterInput",
  "description": "Request body for POST /auth/register",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 100
    },
    "email": {
      "type": "string",
      "pattern": "^[^@\\s]+@[^@\\s]+\\.[^@\\s]+$"
    },
    "password": {
      "type": "string",
      "minLength": 8,
      "maxLength": 128
    }
  },
  "required": ["name", "email", "password"],
  "additionalProperties": false
}
