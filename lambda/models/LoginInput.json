{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "title": "LoginInput",
  "description": "Request body for POST /auth/login",
  "type": "object",
  "properties": {
    "email": {
      "type": "string",
      "pattern": "^[^@\\s]+@[^@\\s]+\\.[^@\\s]+$"
    },
    "password": {
      "type": "string",
      "minLength": 1
    }
  },
  "required": ["email", "password"],
  "additionalProperties": false
}
