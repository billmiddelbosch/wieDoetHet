{
  "name": "wiedoehet-lambda",
  "version": "1.0.0",
  "type": "module",
  "description": "wieDoetHet Lambda backend — Node.js 24, AWS SDK v3, zero native dependencies",
  "engines": {
    "node": ">=24"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.750.0",
    "@aws-sdk/lib-dynamodb": "^3.750.0"
  },
  "scripts": {
    "bundle:auth":   "esbuild wiedoethet-auth/index.js   --bundle --platform=node --target=node24 --external:@aws-sdk/* --outfile=dist/wiedoethet-auth/index.js   --format=cjs",
    "bundle:groups": "esbuild wiedoethet-groups/index.js --bundle --platform=node --target=node24 --external:@aws-sdk/* --outfile=dist/wiedoethet-groups/index.js --format=cjs",
    "bundle:tasks":  "esbuild wiedoethet-tasks/index.js  --bundle --platform=node --target=node24 --external:@aws-sdk/* --outfile=dist/wiedoethet-tasks/index.js  --format=cjs",
    "bundle:claims": "esbuild wiedoethet-claims/index.js --bundle --platform=node --target=node24 --external:@aws-sdk/* --outfile=dist/wiedoethet-claims/index.js --format=cjs",
    "bundle": "npm run bundle:auth && npm run bundle:groups && npm run bundle:tasks && npm run bundle:claims"
  },
  "devDependencies": {
    "esbuild": "^0.27.3"
  }
}
